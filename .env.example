# Flask
SECRET_KEY=your-secret-key-change-in-production

# Entra ID / OIDC — use either OIDC_AUTHORITY or ENTRA_TENANT_ID
# Full authority URL (preferred):
OIDC_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
# Or set tenant ID only (authority becomes https://login.microsoftonline.com/ENTRA_TENANT_ID):
# ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:5000/auth/oidc/callback
# Optional; default is openid profile email
# OIDC_SCOPE=openid profile email
